<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="Web based diffs of Hex packages">
    <%= if assigns[:package] && assigns[:from] && assigns[:to] do %>
      <title><%= @package %> <%= @from %>..<%= @to %> | hexdiff</title>
    <% else %>
      <title>hexdiff</title>
    <% end %>

    <script>
      (() => {
        const key = "hexpm-theme";
        let stored = null;
        try { stored = localStorage.getItem(key); } catch (_e) {}
        const sys = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
        const pref = stored === "light" || stored === "dark" ? stored : "system";
        const theme = pref === "system" ? sys : pref;
        document.documentElement.setAttribute("data-theme", theme);
        document.documentElement.setAttribute("data-theme-preference", pref);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>

    <link rel="icon" type="image/svg+xml" href={~p"/images/hex-full.svg"} />
    <link rel="stylesheet" href={~p"/css/app.css"}/>
    <script defer type="text/javascript" src={~p"/js/app.js"}></script>

    <%= if host = Application.get_env(:diff, :host) do %>
      <script async defer src={"https://s.#{host}/js/script.js"}></script>
    <% end %>
  </head>
  <body>
    <%= @inner_content %>
  </body>
</html>
